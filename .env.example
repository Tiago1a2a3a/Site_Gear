# URL pública usada para gerar metadados e imagens OpenGraph absolutas.
SITE_URL=http://localhost:3000

# Supabase publico. A chave publicavel pode ir ao navegador; a service role nao.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Somente para o Route Handler server-only de exclusao permanente de conta.
SUPABASE_SERVICE_ROLE_KEY=

# Usadas apenas pelo Supabase CLI local quando o provedor GitHub for habilitado.
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
